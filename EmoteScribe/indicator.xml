<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\..\FrameXML\UI.xsd">
  <!-- Sending indicator in the bottom-left corner of the screen. -->
	<Font name="EmoteScribeSendingFont" font="Fonts\ARIALN.TTF" height="10" 
        virtual="true" outline="NORMAL">
		<Color r="1.0" g="1.0" b="1.0"/>
	</Font>
  
  <Frame name="EmoteScribeSending" enableMouse="false" hidden="true" 
         frameStrata="DIALOG" parent="UIParent">
    <Size x="200" y="20"/>
    <Anchors>
      <Anchor point="BOTTOMLEFT" x="3" y="3"/>
    </Anchors>
    <Layers>
      <Layer level="ARTWORK">
        <FontString parentKey="text" justifyH="LEFT" 
                    font="EmoteScribeSendingFont">
          <Anchors>
            <Anchor point="BOTTOMLEFT"/>
          </Anchors>
        </FontString>
      </Layer>
    </Layers>
  </Frame>
</Ui>
